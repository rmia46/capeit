import { Button, VerticalBox, HorizontalBox, LineEdit, Slider, StandardListView, ScrollView } from "std-widgets.slint";
import { IconDisplay, IconSet } from "@lucide";
import { Theme, PowerProfileUI, ThermalProfileUI } from "theme.slint";
import { Card, HubCard, MiniStat, NavBtn, TabBtn, IconButton, Modal, Toast, ThemedSlider } from "widgets.slint";

export { Theme, PowerProfileUI, ThermalProfileUI }

export component AppWindow inherits Window {
    title: "Capeit - Performance Studio";
    min-width: 1200px;
    min-height: 800px;
    background: Theme.bg_deep;

    // Telemetry
    in property <string> cpu_name: "";
    in property <string> gpu_name: "";
    in property <float> cpu_temp: 0;
    in property <float> gpu_temp: 0;
    in property <int> cpu_clock: 0;
    in property <int> gpu_clock: 0;
    in property <float> cpu_usage: 0;
    in property <float> gpu_usage: 0;
    in property <int> vram_used: 0;
    in property <int> vram_total: 0;
    in property <float> ram_used: 0;
    in property <float> ram_total: 0;
    in property <string> uptime: "";
    in property <string> kernel: "";
    in property <bool> ac_connected: true;
    in property <string> active_power: "";
    in property <string> active_thermal: "";
    in property <bool> is_throttled: false;
    
    // Active Limits
    in property <int> active_cpu_limit: 0;
    in property <int> active_gpu_limit: 0;
    in property <int> active_thermal_limit: 0;
    in property <int> active_gpu_temp_limit: 0;
    in property <int> active_p_short: 0;
    in property <int> active_p_long: 0;
    
    // System Info (Dynamic from inxi)
    in property <string> sys_distro: "";
    in property <string> sys_desktop: "";
    in property <string> sys_kernel: "";
    in property <string> sys_cpu: "";
    in property <string> sys_gpu: "";
    in property <string> sys_ram: "";
    in property <string> sys_model: "";
    in property <string> sys_raw_info: "Gathering detailed hardware specifications... please wait.";

    in property <string> toast_msg: "";
    in property <bool> show_toast: false;
    in property <bool> toast_is_error: false;
    
    // Config
    in property <[PowerProfileUI]> power_profiles: [];
    in property <[ThermalProfileUI]> thermal_profiles: [];
    
    in-out property <int> active_side: 0;
    in-out property <int> active_tab: 0;
    property <bool> show_create_modal: false;
    
    // Modal state
    property <bool> is_editing: false;
    property <string> current_name: "";
    property <string> current_cpu: "3000";
    property <string> current_gpu: "1800";
    property <string> current_ps: "45";
    property <string> current_pl: "35";

    // Decoupled slider states
    in-out property <float> manual_cpu_val: 3000;
    in-out property <float> manual_thermal_val: 5;
    in-out property <float> manual_gpu_temp_val: 80;

    callback apply_power(string);
    callback apply_thermal(string);
    callback delete_power(string);
    callback save_power(PowerProfileUI);
    callback set_manual(string, int);

    Rectangle {
        HorizontalBox {
            padding: 0; spacing: 0;

            // SIDEBAR
            Rectangle {
                width: 220px;
                background: Theme.bg_sidebar;
                VerticalBox {
                    padding: 20px;
                    spacing: 20px;
                    alignment: start;
                    Text { text: "CAPEIT"; font_size: 28px; font_weight: 900; color: Theme.accent_cyan; horizontal_alignment: center; }
                    NavBtn { 
                        text: "Dashboard"; active: active_side == 0; clicked => { active_side = 0 }
                        IconDisplay { icon: IconSet.LayoutDashboard; stroke: active_side == 0 ? Theme.bg_deep : Theme.text_main; size: 20px; }
                    }
                    NavBtn { 
                        text: "Power Manage"; active: active_side == 1; clicked => { active_side = 1 }
                        IconDisplay { icon: IconSet.Zap; stroke: active_side == 1 ? Theme.bg_deep : Theme.text_main; size: 20px; }
                    }
                    NavBtn { 
                        text: "System Info"; active: active_side == 2; clicked => { active_side = 2 }
                        IconDisplay { icon: IconSet.Info; stroke: active_side == 2 ? Theme.bg_deep : Theme.text_main; size: 20px; }
                    }
                    Rectangle {}
                }
                Rectangle { width: 1px; background: #30363D; x: parent.width - 1px; }
            }

            // MAIN CONTENT
            VerticalBox {
                padding: 25px; spacing: 20px;

                // DASHBOARD
                if active_side == 0 : VerticalBox {
                    spacing: 20px;
                    
                    // TOP HUB ROW
                    HorizontalBox {
                        padding: 0;
                        spacing: 20px;
                        
                        // CPU HUB
                        HubCard {
                            title: "CPU METRICS";
                            horizontal_stretch: 1;
                            VerticalBox {
                                spacing: 12px;
                                alignment: center;
                                MiniStat { label: "USAGE"; value: "\{round(cpu_usage)}%"; progress: cpu_usage/100.0; IconDisplay { icon: IconSet.Gauge; stroke: Theme.text_muted; size: 12px; } }
                                MiniStat { label: "TEMPERATURE"; value: "\{round(cpu_temp)}°C"; progress: cpu_temp/100.0; bar_color: Theme.error; IconDisplay { icon: IconSet.Thermometer; stroke: Theme.error; size: 12px; } }
                                MiniStat { label: "CLOCK"; value: "\{cpu_clock}MHz"; progress: cpu_clock/5000.0; bar_color: Theme.accent_blue; IconDisplay { icon: IconSet.Activity; stroke: Theme.accent_blue; size: 12px; } }
                            }
                        }
                        
                        // GPU HUB
                        HubCard {
                            title: "GPU METRICS";
                            horizontal_stretch: 1;
                            VerticalBox {
                                spacing: 12px;
                                alignment: center;
                                MiniStat { label: "USAGE"; value: "\{round(gpu_usage)}%"; progress: gpu_usage/100.0; IconDisplay { icon: IconSet.Gauge; stroke: Theme.text_muted; size: 12px; } }
                                MiniStat { label: "VRAM"; value: "\{vram_used}MB"; progress: vram_total > 0 ? vram_used/vram_total : 0; bar_color: Theme.success; IconDisplay { icon: IconSet.HardDrive; stroke: Theme.success; size: 12px; } }
                                MiniStat { label: "CLOCK"; value: "\{gpu_clock}MHz"; progress: gpu_clock/2500.0; bar_color: Theme.accent_blue; IconDisplay { icon: IconSet.Activity; stroke: Theme.accent_blue; size: 12px; } }
                            }
                        }
                    }

                    // SYSTEM HEALTH ROW
                    HubCard {
                        title: "SYSTEM HEALTH";
                        HorizontalBox {
                            padding: 0; spacing: 30px;
                            alignment: center;
                            MiniStat { 
                                label: "RAM USAGE"; 
                                value: "\{round(ram_used*10)/10.0} / \{round(ram_total*10)/10.0} GB"; 
                                progress: ram_total > 0 ? ram_used/ram_total : 0; 
                                horizontal_stretch: 1; 
                                IconDisplay { icon: IconSet.MemoryStick; stroke: Theme.accent_cyan; size: 14px; }
                            }
                            MiniStat { 
                                label: "POWER SOURCE"; 
                                value: ac_connected ? "AC ADAPTER" : "BATTERY"; 
                                progress: ac_connected ? 1.0 : 0.5; 
                                bar_color: Theme.warning; 
                                horizontal_stretch: 1; 
                                IconDisplay { icon: IconSet.PlugZap; stroke: Theme.warning; size: 14px; }
                            }
                            
                            VerticalBox {
                                alignment: center;
                                Rectangle {
                                    width: 170px; height: 45px;
                                    background: is_throttled ? Theme.error.darker(0.5) : transparent;
                                    border_radius: 8px;
                                    border_width: 1px;
                                    border_color: is_throttled ? Theme.error : Theme.success;
                                    HorizontalBox {
                                        padding: 8px; spacing: 8px; alignment: center;
                                        if is_throttled : VerticalLayout { alignment: center; IconDisplay { icon: IconSet.ShieldAlert; stroke: Theme.error; size: 16px; } }
                                        if !is_throttled : VerticalLayout { alignment: center; IconDisplay { icon: IconSet.ShieldCheck; stroke: Theme.success; size: 16px; } }
                                        Text { 
                                            text: is_throttled ? "THROTTLED" : "OPTIMAL"; 
                                            color: is_throttled ? Theme.error : Theme.success; 
                                            font_weight: 900; 
                                            font_size: 11px;
                                            vertical_alignment: center; 
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // PROFILE STATUS ROW
                    HubCard {
                        title: "PROFILE STATUS";
                        VerticalBox {
                            padding: 0; spacing: 20px;
                            HorizontalBox {
                                padding: 0; spacing: 20px;
                                alignment: space-between;
                                
                                // CPU CAPS
                                VerticalBox {
                                    alignment: center; spacing: 4px; horizontal_stretch: 1;
                                    HorizontalBox {
                                        spacing: 6px; alignment: center;
                                        VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Cpu; stroke: Theme.text_muted; size: 12px; } }
                                        Text { text: "CPU STATUS"; color: Theme.text_muted; font_size: 10px; font_weight: 700; vertical_alignment: center; }
                                    }
                                    Text { text: cpu_name; color: Theme.text_main; font_size: 14px; font_weight: 700; overflow: elide; }
                                    Text { text: "Cap: \{active_cpu_limit} MHz | TJ Limit: \{active_thermal_limit}°C"; color: Theme.text_muted; font_size: 11px; }
                                    Text { text: "PS: \{active_p_short}W | PL: \{active_p_long}W"; color: Theme.accent_blue; font_size: 11px; font_weight: 700; }
                                }

                                Rectangle { width: 1px; background: #30363D; height: 40px; }

                                // GPU CAPS
                                VerticalBox {
                                    alignment: center; spacing: 4px; horizontal_stretch: 1;
                                    HorizontalBox {
                                        spacing: 6px; alignment: center;
                                        VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Monitor; stroke: Theme.text_muted; size: 12px; } }
                                        Text { text: "GPU STATUS"; color: Theme.text_muted; font_size: 10px; font_weight: 700; vertical_alignment: center; }
                                    }
                                    Text { text: gpu_name; color: Theme.text_main; font_size: 14px; font_weight: 700; overflow: elide; }
                                    Text { text: "Cap: \{active_gpu_limit} MHz | Temp Cap: \{active_gpu_temp_limit}°C"; color: Theme.text_muted; font_size: 11px; }
                                }

                                Rectangle { width: 1px; background: #30363D; height: 40px; }

                                // ACTIVE PROFILES (Horizontal Stack)
                                VerticalBox {
                                    alignment: center; spacing: 8px; horizontal_stretch: 1;
                                    Text { text: "ACTIVE PROFILES"; color: Theme.text_muted; font_size: 10px; font_weight: 700; }
                                    HorizontalBox {
                                        spacing: 8px;
                                        alignment: center;
                                        Rectangle { 
                                            background: Theme.accent_blue.with-alpha(0.15); 
                                            border_radius: 4px; border_width: 1px; border_color: Theme.accent_blue; 
                                            height: 26px; horizontal_stretch: 1; min-width: 100px;
                                            HorizontalBox { 
                                                padding: 4px; spacing: 6px; alignment: center;
                                                VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Zap; stroke: Theme.accent_blue; size: 12px; } }
                                                Text { text: active_power; color: Theme.accent_blue; font_weight: 700; font_size: 11px; vertical_alignment: center; } 
                                            } 
                                        }
                                        Rectangle { 
                                            background: Theme.accent_cyan.with-alpha(0.15); 
                                            border_radius: 4px; border_width: 1px; border_color: Theme.accent_cyan; 
                                            height: 26px; horizontal_stretch: 1; min-width: 100px;
                                            HorizontalBox { 
                                                padding: 4px; spacing: 6px; alignment: center;
                                                VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Flame; stroke: Theme.accent_cyan; size: 12px; } }
                                                Text { text: active_thermal; color: Theme.accent_cyan; font_weight: 700; font_size: 11px; vertical_alignment: center; } 
                                            } 
                                        }
                                    }
                                }
                            }
                        }
                    }
                    Rectangle { vertical_stretch: 1; } // Local spacer for dashboard top-alignment
                }

                // POWER MANAGE
                if active_side == 1 : VerticalBox {
                    spacing: 20px;
                    vertical_stretch: 1;
                    HorizontalBox {
                        alignment: space-between;
                        HorizontalBox {
                            height: 45px; spacing: 8px;
                            TabBtn { text: "Power Profiles"; active: active_tab == 0; clicked => { active_tab = 0 } }
                            TabBtn { text: "Thermal Profiles"; active: active_tab == 1; clicked => { active_tab = 1 } }
                            TabBtn { text: "Manual Overrides"; active: active_tab == 2; clicked => { active_tab = 2 } }
                        }
                        IconButton {
                            primary: true;
                            width: 140px;
                            clicked => { 
                                current_name = ""; current_cpu = "3000"; current_gpu = "1800"; current_ps = "45"; current_pl = "35";
                                is_editing = false; show_create_modal = true; 
                            }
                            HorizontalBox {
                                spacing: 8px;
                                VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Plus; size: 16px; stroke: Theme.bg_deep; } }
                                Text { text: "NEW PROFILE"; color: Theme.bg_deep; font_weight: 800; font_size: 11px; vertical_alignment: center; }
                            }
                        }
                    }

                    if active_tab == 0 : ScrollView {
                        vertical_stretch: 1;
                        VerticalBox {
                            spacing: 12px;
                            for p in power_profiles : Card {
                                height: 90px;
                                HorizontalBox {
                                    padding: 16px;
                                    VerticalBox {
                                        alignment: center;
                                        Text { text: p.name; color: active_power == p.name ? Theme.accent_cyan : Theme.text_main; font_weight: 700; font_size: 16px; }
                                        Text { text: p.description; color: Theme.text_muted; font_size: 12px; }
                                    }
                                    Rectangle {}
                                    VerticalBox {
                                        alignment: center;
                                        Text { text: "CPU: \{p.cpu_mhz}MHz | GPU: \{p.gpu_mhz}MHz"; color: Theme.text_main; font_size: 12px; }
                                        Text { text: "Power: \{p.p_short}W / \{p.p_long}W"; color: Theme.text_muted; font_size: 11px; }
                                    }
                                    HorizontalBox {
                                        spacing: 8px;
                                        IconButton { 
                                            primary: active_power == p.name;
                                            clicked => { root.apply_power(p.name) } 
                                            IconDisplay { icon: IconSet.Check; stroke: active_power == p.name ? Theme.bg_deep : Theme.text_main; size: 18px; }
                                        }
                                        if !p.is_system : IconButton { 
                                            clicked => { 
                                                current_name = p.name; current_cpu = "\{p.cpu_mhz}"; current_gpu = "\{p.gpu_mhz}"; 
                                                current_ps = "\{p.p_short}"; current_pl = "\{p.p_long}"; 
                                                is_editing = true; show_create_modal = true; 
                                            } 
                                            IconDisplay { icon: IconSet.Pencil; stroke: Theme.text_main; size: 16px; }
                                        }
                                        if !p.is_system : IconButton { 
                                            icon_color: Theme.error;
                                            clicked => { root.delete_power(p.name) } 
                                            IconDisplay { icon: IconSet.Trash2; stroke: Theme.error; size: 16px; }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    if active_tab == 1 : ScrollView {
                        vertical_stretch: 1;
                        VerticalBox {
                            spacing: 12px;
                            for t in thermal_profiles : Card {
                                height: 80px;
                                HorizontalBox {
                                    padding: 16px;
                                    VerticalBox {
                                        alignment: center;
                                        Text { text: t.name; color: active_thermal == t.name ? Theme.accent_cyan : Theme.text_main; font_weight: 700; font_size: 16px; }
                                        Text { text: t.description; color: Theme.text_muted; font_size: 12px; }
                                    }
                                    Rectangle {}
                                    Text { text: "TJ Offset: -\{t.tj_offset}°C | GPU Limit: \{t.gpu_limit}°C"; color: Theme.text_main; font_size: 12px; vertical_alignment: center; }
                                    IconButton { 
                                        primary: active_thermal == t.name;
                                        clicked => { root.apply_thermal(t.name) } 
                                        IconDisplay { icon: IconSet.Check; stroke: active_thermal == t.name ? Theme.bg_deep : Theme.text_main; size: 18px; }
                                    }
                                }
                            }
                        }
                    }

                    if active_tab == 2 : VerticalBox {
                        vertical_stretch: 1;
                        spacing: 20px;
                        HubCard {
                            title: "MANUAL OVERRIDES";
                            VerticalBox {
                                spacing: 20px;
                                VerticalBox {
                                    HorizontalBox { spacing: 6px; alignment: start; VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Cpu; size: 14px; stroke: Theme.text_muted; } } Text { text: "CPU Max Clock (MHz)"; color: Theme.text_muted; vertical_alignment: center; } }
                                    HorizontalBox {
                                        s1 := ThemedSlider { minimum: 800; maximum: 5000; value <=> root.manual_cpu_val; }
                                        Text { text: "\{round(s1.value)}"; color: Theme.text_main; width: 60px; }
                                        IconButton { primary: true; clicked => { root.set_manual("cpu", round(s1.value)) } IconDisplay { icon: IconSet.Save; size: 16px; stroke: Theme.bg_deep; } }
                                    }
                                }
                                VerticalBox {
                                    HorizontalBox { spacing: 6px; alignment: start; VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Thermometer; size: 14px; stroke: Theme.text_muted; } } Text { text: "Thermal Offset (-°C)"; color: Theme.text_muted; vertical_alignment: center; } }
                                    HorizontalBox {
                                        s2 := ThemedSlider { minimum: 0; maximum: 30; value <=> root.manual_thermal_val; }
                                        Text { text: "-\{round(s2.value)}"; color: Theme.text_main; width: 60px; }
                                        IconButton { primary: true; clicked => { root.set_manual("thermal", round(s2.value)) } IconDisplay { icon: IconSet.Save; size: 16px; stroke: Theme.bg_deep; } }
                                    }
                                }
                                VerticalBox {
                                    HorizontalBox { spacing: 6px; alignment: start; VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Monitor; size: 14px; stroke: Theme.text_muted; } } Text { text: "GPU Temp Limit (°C)"; color: Theme.text_muted; vertical_alignment: center; } }
                                    HorizontalBox {
                                        s3 := ThemedSlider { minimum: 60; maximum: 95; value <=> root.manual_gpu_temp_val; }
                                        Text { text: "\{round(s3.value)}"; color: Theme.text_main; width: 60px; }
                                        IconButton { primary: true; clicked => { root.set_manual("gputemp", round(s3.value)) } IconDisplay { icon: IconSet.Save; size: 16px; stroke: Theme.bg_deep; } }
                                    }
                                }
                            }
                        }
                        Rectangle { vertical_stretch: 1; } // Local spacer for manual tab
                    }
                }

                // SYSTEM INFO
                if active_side == 2 : ScrollView {
                    vertical_stretch: 1;
                    VerticalBox {
                        spacing: 20px;
                        padding: 0;
                        
                        HubCard {
                            title: "OPERATING SYSTEM";
                            VerticalBox {
                                spacing: 12px;
                                HorizontalBox { 
                                    spacing: 8px; alignment: start;
                                    VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Monitor; size: 16px; stroke: Theme.accent_cyan; } }
                                    HorizontalBox { alignment: start; Text { text: "Distribution:"; color: Theme.text_muted; width: 140px; vertical_alignment: center; } Text { text: sys_distro; color: Theme.text_main; font_weight: 700; wrap: word-wrap; horizontal_stretch: 1; vertical_alignment: center; } }
                                }
                                HorizontalBox { 
                                    spacing: 8px; alignment: start;
                                    VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Settings; size: 16px; stroke: Theme.text_muted; } }
                                    HorizontalBox { alignment: start; Text { text: "Desktop Env:"; color: Theme.text_muted; width: 140px; vertical_alignment: center; } Text { text: sys_desktop; color: Theme.text_main; wrap: word-wrap; horizontal_stretch: 1; vertical_alignment: center; } }
                                }
                                HorizontalBox { 
                                    spacing: 8px; alignment: start;
                                    VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Activity; size: 16px; stroke: Theme.text_muted; } }
                                    HorizontalBox { alignment: start; Text { text: "Kernel Version:"; color: Theme.text_muted; width: 140px; vertical_alignment: center; } Text { text: sys_kernel; color: Theme.text_main; wrap: word-wrap; horizontal_stretch: 1; vertical_alignment: center; } }
                                }
                            }
                        }

                        HubCard {
                            title: "HARDWARE SPECIFICATIONS (RAW)";
                            height: 450px;
                            VerticalBox {
                                padding: 0; spacing: 8px;
                                HorizontalBox { spacing: 8px; alignment: start; VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Cpu; size: 16px; stroke: Theme.accent_blue; } } Text { text: "DETAILED REPORT"; color: Theme.text_muted; font_size: 10px; font_weight: 700; vertical_alignment: center; } }
                                ScrollView {
                                    vertical_stretch: 1;
                                    viewport-height: raw_box.preferred-height;
                                    raw_box := VerticalBox {
                                        padding: 10px;
                                        raw_txt := Text {
                                            text: root.sys_raw_info;
                                            color: Theme.text_main;
                                            font_size: 13px;
                                            wrap: word-wrap;
                                            horizontal-alignment: left;
                                        }
                                    }
                                }
                            }
                        }

                        HubCard {
                            title: "CAPEIT ENVIRONMENT";
                            VerticalBox {
                                spacing: 12px;
                                HorizontalBox { 
                                    spacing: 8px; alignment: start;
                                    VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Info; size: 16px; stroke: Theme.success; } }
                                    HorizontalBox { alignment: start; Text { text: "Uptime:"; color: Theme.text_muted; width: 140px; vertical_alignment: center; } Text { text: uptime; color: Theme.text_main; horizontal_stretch: 1; vertical_alignment: center; } }
                                }
                                HorizontalBox { 
                                    spacing: 8px; alignment: start;
                                    VerticalLayout { alignment: center; IconDisplay { icon: IconSet.HardDrive; size: 16px; stroke: Theme.text_muted; } }
                                    HorizontalBox { alignment: start; Text { text: "Config Path:"; color: Theme.text_muted; width: 140px; vertical_alignment: center; } Text { text: "~/.config/capeit/"; color: Theme.accent_cyan; horizontal_stretch: 1; vertical_alignment: center; } }
                                }
                                HorizontalBox { 
                                    spacing: 8px; alignment: start;
                                    VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Zap; size: 16px; stroke: Theme.text_muted; } }
                                    HorizontalBox { alignment: start; Text { text: "Daemon Socket:"; color: Theme.text_muted; width: 140px; vertical_alignment: center; } Text { text: "/tmp/capeit.sock"; color: Theme.success; horizontal_stretch: 1; vertical_alignment: center; } }
                                }
                            }
                        }
                    }
                }
            }
        }

        // Toast Overlay
        if show_toast : VerticalBox {
            alignment: end; padding_bottom: 20px;
            HorizontalBox { alignment: center; Toast { text: toast_msg; is_error: toast_is_error; } }
        }

        // Modal Overlay
        if show_create_modal : Modal {
            VerticalBox {
                alignment: center;
                HorizontalBox {
                    alignment: center;
                    Card {
                        width: 450px;
                        VerticalBox {
                            padding: 24px; spacing: 20px;
                            Text { text: is_editing ? "EDIT POWER PROFILE" : "CREATE POWER PROFILE"; font_size: 20px; font_weight: 900; color: Theme.accent_cyan; }
                            VerticalBox {
                                spacing: 4px; Text { text: "PROFILE NAME"; color: Theme.text_muted; font_size: 11px; font_weight: 700; }
                                LineEdit { text <=> current_name; enabled: !is_editing; }
                            }
                            HorizontalBox {
                                spacing: 16px;
                                VerticalBox { spacing: 4px; Text { text: "CPU MAX MHZ"; color: Theme.text_muted; font_size: 11px; font_weight: 700; } LineEdit { text <=> current_cpu; } }
                                VerticalBox { spacing: 4px; Text { text: "GPU LOCK MHZ"; color: Theme.text_muted; font_size: 11px; font_weight: 700; } LineEdit { text <=> current_gpu; } }
                            }
                            HorizontalBox {
                                spacing: 16px;
                                VerticalBox { spacing: 4px; Text { text: "PL SHORT (W)"; color: Theme.text_muted; font_size: 11px; font_weight: 700; } LineEdit { text <=> current_ps; } }
                                VerticalBox { spacing: 4px; Text { text: "PL LONG (W)"; color: Theme.text_muted; font_size: 11px; font_weight: 700; } LineEdit { text <=> current_pl; } }
                            }
                            HorizontalBox {
                                spacing: 16px; alignment: end;
                                IconButton { 
                                    width: 100px;
                                    clicked => { show_create_modal = false } 
                                    HorizontalBox { spacing: 6px; alignment: center; VerticalLayout { alignment: center; IconDisplay { icon: IconSet.X; size: 14px; stroke: Theme.text_main; } } Text { text: "CANCEL"; font_weight: 700; font_size: 11px; vertical_alignment: center; } }
                                }
                                IconButton { 
                                    primary: true; width: 100px;
                                    clicked => {
                                        root.save_power({ name: current_name, description: "Custom performance profile", cpu_mhz: current_cpu.to_float(), gpu_mhz: current_gpu.to_float(), p_short: current_ps.to_float(), p_long: current_pl.to_float(), is_system: false });
                                        show_create_modal = false;
                                    }
                                    HorizontalBox { spacing: 6px; alignment: center; VerticalLayout { alignment: center; IconDisplay { icon: IconSet.Save; size: 14px; stroke: Theme.bg_deep; } } Text { text: is_editing ? "UPDATE" : "SAVE"; color: Theme.bg_deep; font_weight: 800; font_size: 11px; vertical_alignment: center; } }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
